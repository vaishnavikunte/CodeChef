Minimum Number of Ones

Input
6
6
8
2
3
5
100


Output
3
4
1
1
2
50

import java.util.*;
public class Main
{
	public static void main(String[] args) {
	    int t;
	    Scanner sc = new Scanner(System.in);
	    t = sc.nextInt();
	    while(t --> 0){
	        int a = sc.nextInt();
	        System.out.println(a/2);
	    }
		
	}
}
